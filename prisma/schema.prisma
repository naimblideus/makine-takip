generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  PERSONEL
  MUHASEBE
}

enum MachineType {
  FORKLIFT
  EKSAVATOR
  VINC
  DOZER
  KEPCE
  GREYDER
  SILINDIR
  KAMYON
  BEKO_LODER
  DIGER
}

enum MachineStatus {
  MUSAIT
  KIRADA
  BAKIMDA
  ARIZALI
}

enum RentalStatus {
  AKTIF
  TAMAMLANDI
  IPTAL
}

enum RentalPeriodType {
  SAATLIK
  GUNLUK
  HAFTALIK
  AYLIK
}

enum PaymentMethod {
  NAKIT
  KREDI_KARTI
  HAVALE_EFT
  CEK
  SENET
}

enum PaymentStatus {
  ODENDI
  BEKLIYOR
  GECIKTI
  IPTAL
}

enum MaintenanceType {
  YAG_DEGISIMI
  FILTRE
  GENEL_BAKIM
  REVIZYON
  LASTIK
  DIGER
}

enum FuelLevel {
  TAM
  YARI
  CEYREK
  BOS
}

enum TimesheetType {
  NORMAL
  FAZLA_MESAI
  RESMI_TATIL
}

enum InvoiceStatus {
  TASLAK
  ONAYLANDI
  ODENDI
  KISMI_ODENDI
  GECIKTI
  IPTAL
}

enum GpsAction {
  ENGINE_STOP
  ENGINE_START
  SPEED_ALERT
  GEOFENCE_BREACH
  FUEL_THEFT_ALERT
  UNAUTHORIZED_USE
  IDLE_ALERT
}

enum NotificationType {
  BAKIM_YAKLASIYOR
  BAKIM_GECIKTI
  SIGORTA_DOLACAK
  MUAYENE_DOLACAK
  YAKIT_HIRSIZLIGI
  GEOFENCE_IHLALI
  YETKISIZ_KULLANIM
  HIZ_IHLALI
  BOSTA_CALISIYOR
  MOTOR_DURDU
  OPERATOR_BELGESI_DOLACAK
  ARIZA_BILDIRIMI
}

// ─── MODELS ──────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  logo      String?
  address   String?
  phone     String?
  email     String?
  taxOffice String?  @map("tax_office")
  taxNumber String?  @map("tax_number")

  // ── Abonelik / lisans (SaaS gelir modeli) ──
  plan               String    @default("PRO") @map("plan") // TEMEL, PRO, PLATFORM
  subscriptionStatus String    @default("ACTIVE") @map("subscription_status") // TRIAL, ACTIVE, PAST_DUE, CANCELED
  trialEndsAt        DateTime? @map("trial_ends_at")
  machineLimit       Int       @default(50) @map("machine_limit")
  lateFeeMonthlyRate Decimal   @default(0) @map("late_fee_monthly_rate") @db.Decimal(5, 2)
  billingCycle       String    @default("MONTHLY") @map("billing_cycle")

  // ── Bayi (dealer) bağı + alarm kanalı + KVKK ──
  dealerId      String? @map("dealer_id")
  alertPhone    String? @map("alert_phone")
  alertEmail    String? @map("alert_email")
  alertWhatsapp String? @map("alert_whatsapp")
  kvkkText      String? @map("kvkk_text")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dealer               Dealer?              @relation(fields: [dealerId], references: [id])
  users                User[]
  machines             Machine[]
  operators            Operator[]
  customers            Customer[]
  sites                Site[]
  rentals              Rental[]
  fuelEntries          FuelEntry[]
  maintenances         Maintenance[]
  invoices             Invoice[]
  payments             Payment[]
  timesheets           Timesheet[]
  gpsLogs              GpsLog[]
  engineSessions       EngineSession[]
  geofences            Geofence[]
  geofenceBreaches     GeofenceBreach[]
  fuelTheftAlerts      FuelTheftAlert[]
  systemNotifications  SystemNotification[]
  hakedisler           Hakedis[]
  documents            Document[]
  maintenanceSchedules MaintenanceSchedule[]
  pricingRules         PricingRule[]
  depots               Depot[]
  machineTransfers     MachineTransfer[]
  incomeExpenses       IncomeExpense[]
  machineAmortizations MachineAmortization[]
  customerRatings      CustomerRating[]
  customerInteractions CustomerInteraction[]
  operatorScores       OperatorScore[]
  quotes               Quote[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @unique
  password  String
  name      String
  role      Role     @default(PERSONEL)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
  @@index([tenantId, isActive])
}

model Machine {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  plate        String?
  serialNumber String?       @map("serial_number")
  brand        String
  model        String
  year         Int?
  type         MachineType
  status       MachineStatus @default(MUSAIT)
  photo        String?

  // Fiyatlar
  hourlyRate      Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  dailyRate       Decimal? @map("daily_rate") @db.Decimal(10, 2)
  weeklyRate      Decimal? @map("weekly_rate") @db.Decimal(10, 2)
  monthlyRate     Decimal? @map("monthly_rate") @db.Decimal(10, 2)
  operatorIncRate Decimal? @map("operator_inc_rate") @db.Decimal(10, 2)

  // Belgeler
  registrationDoc  String?   @map("registration_doc")
  insuranceExpiry  DateTime? @map("insurance_expiry")
  inspectionExpiry DateTime? @map("inspection_expiry")

  // Sayaç
  totalHours Decimal @default(0) @map("total_hours") @db.Decimal(10, 1)

  // GPS & Telemetri
  traccarDeviceId      String?  @map("traccar_device_id")
  speedLimit           Int?     @map("speed_limit")
  gpsEnabled           Boolean  @default(false) @map("gps_enabled")
  fuelCapacity         Decimal? @map("fuel_capacity") @db.Decimal(10, 1)
  fuelSensorEnabled    Boolean  @default(false) @map("fuel_sensor_enabled")
  engineHoursSensor    Boolean  @default(false) @map("engine_hours_sensor")
  idleThresholdMinutes Int      @default(15) @map("idle_threshold_minutes")

  // Marketplace (kiralama borsası)
  marketplaceListed   Boolean @default(false) @map("marketplace_listed")
  marketplaceCity     String? @map("marketplace_city")
  marketplaceNote     String? @map("marketplace_note")
  marketplaceFeatured Boolean @default(false) @map("marketplace_featured")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentals              Rental[]
  fuelEntries          FuelEntry[]
  maintenances         Maintenance[]
  gpsLogs              GpsLog[]
  engineSessions       EngineSession[]
  geofenceMachines     GeofenceMachine[]
  geofenceBreaches     GeofenceBreach[]
  fuelTheftAlerts      FuelTheftAlert[]
  hakedisler           Hakedis[]
  maintenanceSchedules MaintenanceSchedule[]
  transfers            MachineTransfer[]
  amortization         MachineAmortization?

  @@map("machines")
  @@index([tenantId, status])
}

model Operator {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  name          String
  tcNumber      String?       @map("tc_number")
  phone         String?
  address       String?
  licenseClass  String?       @map("license_class")
  licenseExpiry DateTime?     @map("license_expiry")
  machineTypes  MachineType[] @map("machine_types")

  dailyWage  Decimal? @map("daily_wage") @db.Decimal(10, 2)
  hourlyWage Decimal? @map("hourly_wage") @db.Decimal(10, 2)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentals        Rental[]
  timesheets     Timesheet[]
  engineSessions EngineSession[]
  scores         OperatorScore[]

  @@map("operators")
  @@index([tenantId, isActive])
}

model Customer {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  companyName   String  @map("company_name")
  contactPerson String? @map("contact_person")
  phone         String?
  email         String?
  address       String?
  taxOffice     String? @map("tax_office")
  taxNumber     String? @map("tax_number")

  isBlacklisted   Boolean @default(false) @map("is_blacklisted")
  blacklistReason String? @map("blacklist_reason")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sites        Site[]
  rentals      Rental[]
  invoices     Invoice[]
  hakedisler   Hakedis[]
  rating       CustomerRating?
  interactions CustomerInteraction[]
  quotes       Quote[]

  @@map("customers")
  @@index([tenantId])
}

model Site {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  customerId    String  @map("customer_id")
  name          String
  address       String?
  mapsLink      String? @map("maps_link")
  contactPerson String? @map("contact_person")
  contactPhone  String? @map("contact_phone")

  // GPS koordinatları
  lat                   Float?
  lng                   Float?
  defaultGeofenceRadius Int?   @default(500) @map("default_geofence_radius")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rentals   Rental[]
  geofences Geofence[]

  @@map("sites")
  @@index([tenantId, customerId])
}

model Rental {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  machineId  String  @map("machine_id")
  customerId String  @map("customer_id")
  siteId     String? @map("site_id")
  operatorId String? @map("operator_id")

  status           RentalStatus     @default(AKTIF)
  periodType       RentalPeriodType @map("period_type")
  unitPrice        Decimal          @map("unit_price") @db.Decimal(10, 2)
  operatorIncluded Boolean          @default(false) @map("operator_included")

  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  actualEndDate DateTime? @map("actual_end_date")

  // Teslim bilgileri
  deliveryHours Decimal?   @map("delivery_hours") @db.Decimal(10, 1)
  deliveryKm    Decimal?   @map("delivery_km") @db.Decimal(10, 1)
  deliveryFuel  FuelLevel? @map("delivery_fuel")

  // İade bilgileri
  returnHours Decimal?   @map("return_hours") @db.Decimal(10, 1)
  returnKm    Decimal?   @map("return_km") @db.Decimal(10, 1)
  returnFuel  FuelLevel? @map("return_fuel")

  deposit Decimal? @db.Decimal(10, 2)
  notes   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine        Machine         @relation(fields: [machineId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id])
  site           Site?           @relation(fields: [siteId], references: [id])
  operator       Operator?       @relation(fields: [operatorId], references: [id])
  contract       Contract?
  damageRecords  DamageRecord[]
  invoices       Invoice[]
  timesheets     Timesheet[]
  engineSessions EngineSession[]
  hakedisler     Hakedis[]

  @@map("rentals")
  @@index([tenantId, status])
  @@index([tenantId, machineId])
}

model Contract {
  id            String    @id @default(uuid())
  rentalId      String    @unique @map("rental_id")
  pdfPath       String?   @map("pdf_path")
  signatureData String?   @map("signature_data")
  signedAt      DateTime? @map("signed_at")
  sentAt        DateTime? @map("sent_at")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  rental Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

model DamageRecord {
  id                String   @id @default(uuid())
  rentalId          String   @map("rental_id")
  description       String
  location          String?
  photos            String[]
  cost              Decimal? @db.Decimal(10, 2)
  chargedToCustomer Boolean  @default(false) @map("charged_to_customer")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  rental Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("damage_records")
}

model FuelEntry {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  machineId     String   @map("machine_id")
  date          DateTime
  liters        Decimal  @db.Decimal(10, 2)
  cost          Decimal  @db.Decimal(10, 2)
  fuelLevel     String?  @map("fuel_level")
  supplier      String?
  receiptNumber String?  @map("receipt_number")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id])

  @@map("fuel_entries")
  @@index([tenantId, machineId, date])
}

model Maintenance {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  machineId   String          @map("machine_id")
  type        MaintenanceType
  description String?
  cost        Decimal?        @db.Decimal(10, 2)
  parts       String?
  serviceName String?         @map("service_name")
  photos      String[]

  performedAt          DateTime  @map("performed_at")
  machineHoursAt       Decimal?  @map("machine_hours_at") @db.Decimal(10, 1)
  nextMaintenanceHours Decimal?  @map("next_maintenance_hours") @db.Decimal(10, 1)
  nextMaintenanceDate  DateTime? @map("next_maintenance_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id])

  @@map("maintenances")
  @@index([tenantId, machineId, performedAt])
}

model Invoice {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  customerId    String  @map("customer_id")
  rentalId      String? @map("rental_id")
  invoiceNumber String  @map("invoice_number")

  status InvoiceStatus @default(TASLAK)

  subtotal    Decimal @db.Decimal(10, 2)
  taxRate     Decimal @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(10, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)
  lateFee     Decimal? @map("late_fee") @db.Decimal(10, 2)
  hakedisId   String?  @map("hakedis_id")

  items   Json?
  notes   String?
  pdfPath String? @map("pdf_path")

  // e-Fatura / GİB
  efaturaUuid   String?   @map("efatura_uuid")
  efaturaEttn   String?   @map("efatura_ettn")
  efaturaStatus String?   @map("efatura_status") // GONDERILDI, KABUL, RED, MOCK
  efaturaSentAt DateTime? @map("efatura_sent_at")

  // Online ödeme (iyzico / sanal POS)
  payToken       String?  @unique @map("pay_token")
  providerRef    String?  @map("provider_ref")
  providerStatus String?  @map("provider_status") // BEKLIYOR | ODENDI | BASARISIZ
  checkoutUrl    String?  @map("checkout_url")

  issueDate DateTime  @map("issue_date")
  dueDate   DateTime? @map("due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id])
  rental   Rental?   @relation(fields: [rentalId], references: [id])
  payments Payment[]

  @@map("invoices")
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model Payment {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  invoiceId String @map("invoice_id")

  amount Decimal       @db.Decimal(10, 2)
  method PaymentMethod
  status PaymentStatus @default(BEKLIYOR)
  providerRef String?  @map("provider_ref")

  paidAt  DateTime? @map("paid_at")
  dueDate DateTime? @map("due_date")

  reference String?
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
}

model Timesheet {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  operatorId  String        @map("operator_id")
  rentalId    String?       @map("rental_id")
  date        DateTime
  type        TimesheetType @default(NORMAL)
  hoursWorked Decimal       @map("hours_worked") @db.Decimal(4, 1)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  rental   Rental?  @relation(fields: [rentalId], references: [id])

  @@map("timesheets")
  @@index([tenantId, operatorId, date])
}

// ─── GPS & TELEMETRİ MODELLERİ ──────────────────────────

model GpsLog {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  machineId   String    @map("machine_id")
  action      GpsAction
  lat         Float?
  lng         Float?
  speed       Float?
  engineOn    Boolean?  @map("engine_on")
  fuelLevel   Float?    @map("fuel_level")
  triggeredBy String?   @map("triggered_by")
  reason      String?
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("gps_logs")
  @@index([tenantId, machineId, createdAt])
}

model EngineSession {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  machineId       String    @map("machine_id")
  rentalId        String?   @map("rental_id")
  operatorId      String?   @map("operator_id")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int?      @map("duration_minutes")
  idleMinutes     Int?      @map("idle_minutes")
  workMinutes     Int?      @map("work_minutes")
  maxSpeed        Float?    @map("max_speed")
  avgSpeed        Float?    @map("avg_speed")
  fuelConsumed    Float?    @map("fuel_consumed")
  startLat        Float?    @map("start_lat")
  startLng        Float?    @map("start_lng")
  isAuthorized    Boolean   @default(true) @map("is_authorized")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine  Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  rental   Rental?   @relation(fields: [rentalId], references: [id])
  operator Operator? @relation(fields: [operatorId], references: [id])

  @@map("engine_sessions")
  @@index([tenantId, machineId, startedAt])
}

model Geofence {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  siteId         String?  @map("site_id")
  name           String
  type           String   @default("POLYGON")
  coordinates    Json
  isActive       Boolean  @default(true) @map("is_active")
  actionOnBreach String   @default("ALERT") @map("action_on_breach")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site             Site?             @relation(fields: [siteId], references: [id])
  assignedMachines GeofenceMachine[]
  breaches         GeofenceBreach[]

  @@map("geofences")
  @@index([tenantId, isActive])
}

model GeofenceMachine {
  id         String   @id @default(uuid())
  geofenceId String   @map("geofence_id")
  machineId  String   @map("machine_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  geofence Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  machine  Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("geofence_machines")
}

model GeofenceBreach {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  geofenceId  String    @map("geofence_id")
  machineId   String    @map("machine_id")
  lat         Float
  lng         Float
  speed       Float?
  breachType  String    @default("EXIT")
  actionTaken String?   @map("action_taken")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  geofence Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  machine  Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("geofence_breaches")
  @@index([tenantId, machineId, createdAt])
}

model FuelTheftAlert {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  machineId    String   @map("machine_id")
  detectedAt   DateTime @map("detected_at")
  fuelBefore   Float    @map("fuel_before")
  fuelAfter    Float    @map("fuel_after")
  difference   Float
  machineWasOn Boolean  @map("machine_was_on")
  lat          Float?
  lng          Float?
  isResolved   Boolean  @default(false) @map("is_resolved")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("fuel_theft_alerts")
  @@index([tenantId, machineId, isResolved])
}

model SystemNotification {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  type      NotificationType
  title     String
  message   String
  machineId String?          @map("machine_id")
  rentalId  String?          @map("rental_id")
  isRead    Boolean          @default(false) @map("is_read")
  data      Json?
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("system_notifications")
  @@index([tenantId, isRead, createdAt])
}

// ─── YENİ MODELLER — MASTER PROMPT FAZ 1+ ────────────────

enum HakedisStatus {
  TASLAK
  ONAY_BEKLIYOR
  ONAYLANDI
  MUSTERI_ONAY_BEKLIYOR
  MUSTERI_ONAYLADI
  FATURALANDI
  REDDEDILDI
}

model Hakedis {
  id                 String           @id @default(uuid())
  tenantId           String           @map("tenant_id")
  rentalId           String           @map("rental_id")
  machineId          String           @map("machine_id")
  customerId         String           @map("customer_id")
  operatorId         String?          @map("operator_id")
  periodStart        DateTime         @map("period_start")
  periodEnd          DateTime         @map("period_end")
  periodLabel        String           @map("period_label")
  totalHours         Decimal          @default(0) @map("total_hours") @db.Decimal(10, 1)
  workingDays        Int              @default(0) @map("working_days")
  idleHours          Decimal?         @map("idle_hours") @db.Decimal(10, 1)
  overtimeHours      Decimal?         @map("overtime_hours") @db.Decimal(10, 1)
  unitPrice          Decimal          @map("unit_price") @db.Decimal(10, 2)
  periodType         RentalPeriodType @map("period_type")
  subtotal           Decimal          @default(0) @db.Decimal(10, 2)
  fuelCost           Decimal?         @map("fuel_cost") @db.Decimal(10, 2)
  operatorCost       Decimal?         @map("operator_cost") @db.Decimal(10, 2)
  transportCost      Decimal?         @map("transport_cost") @db.Decimal(10, 2)
  extraCosts         Json?            @map("extra_costs")
  discount           Decimal?         @db.Decimal(10, 2)
  taxRate            Decimal          @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount          Decimal          @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount        Decimal          @default(0) @map("total_amount") @db.Decimal(10, 2)
  status             HakedisStatus    @default(TASLAK)
  preparedBy         String?          @map("prepared_by")
  approvedBy         String?          @map("approved_by")
  approvedAt         DateTime?        @map("approved_at")
  sentToCustomerAt   DateTime?        @map("sent_to_customer_at")
  customerApprovedAt DateTime?        @map("customer_approved_at")
  customerToken      String?          @unique @map("customer_token")
  photos             String[]
  gpsReport          Json?            @map("gps_report")
  operatorSignature  String?          @map("operator_signature")
  customerSignature  String?          @map("customer_signature")
  pdfPath            String?          @map("pdf_path")
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rental   Rental   @relation(fields: [rentalId], references: [id])
  machine  Machine  @relation(fields: [machineId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@map("hakedisler")
  @@index([tenantId, status])
}

model Document {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  entityType String    @map("entity_type") // MACHINE, OPERATOR, CUSTOMER, RENTAL
  entityId   String    @map("entity_id")
  type       String // RUHSAT, SIGORTA, MUAYENE, EHLIYET, OPERATOR_BELGESI, SOZLESME, vb.
  title      String
  filePath   String?   @map("file_path")
  expiryDate DateTime? @map("expiry_date")
  alertDays  Int       @default(30) @map("alert_days")
  isExpired  Boolean   @default(false) @map("is_expired")
  isAlerted  Boolean   @default(false) @map("is_alerted")
  notes      String?
  uploadedBy String?   @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("documents")
  @@index([tenantId, expiryDate])
}

model MaintenanceSchedule {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  machineId       String          @map("machine_id")
  type            MaintenanceType
  description     String?
  intervalHours   Int?            @map("interval_hours")
  intervalDays    Int?            @map("interval_days")
  lastPerformedAt DateTime?       @map("last_performed_at")
  lastHoursAt     Decimal?        @map("last_hours_at") @db.Decimal(10, 1)
  nextDueDate     DateTime?       @map("next_due_date")
  nextDueHours    Decimal?        @map("next_due_hours") @db.Decimal(10, 1)
  estimatedCost   Decimal?        @map("estimated_cost") @db.Decimal(10, 2)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("maintenance_schedules")
  @@index([tenantId, nextDueDate])
}

model PricingRule {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  machineType      MachineType      @map("machine_type")
  periodType       RentalPeriodType @map("period_type")
  basePrice        Decimal          @map("base_price") @db.Decimal(10, 2)
  seasonMultiplier Decimal          @default(1) @map("season_multiplier") @db.Decimal(5, 2)
  longTermDiscount Decimal          @default(0) @map("long_term_discount") @db.Decimal(5, 2)
  loyaltyDiscount  Decimal          @default(0) @map("loyalty_discount") @db.Decimal(5, 2)
  operatorIncRate  Decimal          @default(0) @map("operator_inc_rate") @db.Decimal(10, 2)
  minRentalDays    Int?             @map("min_rental_days")
  notes            String?
  isActive         Boolean          @default(true) @map("is_active")
  validFrom        DateTime?        @map("valid_from")
  validTo          DateTime?        @map("valid_to")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
}

model Depot {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  address      String?
  lat          Float?
  lng          Float?
  capacity     Int?
  contactName  String?  @map("contact_name")
  contactPhone String?  @map("contact_phone")
  notes        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transfers MachineTransfer[]

  @@map("depots")
}

model MachineTransfer {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  machineId        String   @map("machine_id")
  fromType         String   @map("from_type") // DEPOT, SITE
  fromId           String   @map("from_id")
  toType           String   @map("to_type") // DEPOT, SITE
  toId             String   @map("to_id")
  transferDate     DateTime @map("transfer_date")
  distance         Decimal? @db.Decimal(10, 1)
  cost             Decimal? @db.Decimal(10, 2)
  transportCompany String?  @map("transport_company")
  status           String   @default("PLANLI") // PLANLI, YOLDA, TAMAMLANDI
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id])
  depot   Depot?  @relation(fields: [toId], references: [id])

  @@map("machine_transfers")
}

model IncomeExpense {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  type          String // GELIR, GIDER
  category      String // KIRALAMA, YAKIT, BAKIM, SIGORTA, NAKLIYE, PERSONEL, VERGI, DIGER
  description   String
  amount        Decimal        @db.Decimal(12, 2)
  date          DateTime
  machineId     String?        @map("machine_id")
  customerId    String?        @map("customer_id")
  invoiceId     String?        @map("invoice_id")
  paymentMethod PaymentMethod?
  reference     String?
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("income_expenses")
  @@index([tenantId, date])
}

model MachineAmortization {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  machineId       String   @unique @map("machine_id")
  purchasePrice   Decimal  @map("purchase_price") @db.Decimal(12, 2)
  purchaseDate    DateTime @map("purchase_date")
  usefulLifeYears Int      @default(5) @map("useful_life_years")
  salvageValue    Decimal  @default(0) @map("salvage_value") @db.Decimal(12, 2)
  currentValue    Decimal  @map("current_value") @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_amortizations")
}

model CustomerRating {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  customerId     String    @unique @map("customer_id")
  paymentScore   Int       @default(50) @map("payment_score")
  loyaltyScore   Int       @default(50) @map("loyalty_score")
  volumeScore    Int       @default(0) @map("volume_score")
  riskScore      Int       @default(50) @map("risk_score")
  totalRentals   Int       @default(0) @map("total_rentals")
  totalRevenue   Decimal   @default(0) @map("total_revenue") @db.Decimal(12, 2)
  avgPaymentDays Int       @default(0) @map("avg_payment_days")
  lastRentalDate DateTime? @map("last_rental_date")
  tier           String    @default("STANDART") // VIP, PREMIUM, STANDART, RISKLI
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_ratings")
}

model CustomerInteraction {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  customerId     String    @map("customer_id")
  type           String // ARAMA, ZIYARET, EMAIL, WHATSAPP, SIKAYET, TEKLIF
  title          String
  description    String?
  outcome        String?
  nextAction     String?   @map("next_action")
  nextActionDate DateTime? @map("next_action_date")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_interactions")
}

model OperatorScore {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  operatorId       String   @map("operator_id")
  period           String // "2026-03"
  attendanceScore  Int      @default(0) @map("attendance_score")
  safetyScore      Int      @default(0) @map("safety_score")
  efficiencyScore  Int      @default(0) @map("efficiency_score")
  maintenanceScore Int      @default(0) @map("maintenance_score")
  totalScore       Int      @default(0) @map("total_score")
  rank             Int?
  badge            String? // ALTIN, GUMUS, BRONZ
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, operatorId, period])
  @@map("operator_scores")
}

// ─── BAYİ (DEALER) — Kanal modeli ────────────────────────
model Dealer {
  id                  String   @id @default(uuid())
  name                String
  contactName         String?  @map("contact_name")
  phone               String?
  email               String?
  city                String?
  commissionFirstYear Decimal  @default(25) @map("commission_first_year") @db.Decimal(5, 2) // %
  commissionRenewal   Decimal  @default(10) @map("commission_renewal") @db.Decimal(5, 2)
  isActive            Boolean  @default(true) @map("is_active")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenants Tenant[]

  @@map("dealers")
}

// ─── TEKLİF (QUOTE) — Para funnel'inin başı ──────────────
enum QuoteStatus {
  TASLAK
  GONDERILDI
  GORUNTULENDI
  KABUL
  RED
  SURESI_DOLDU
  KIRALAMAYA_DONDU
}

model Quote {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  customerId       String?          @map("customer_id")
  customerName     String           @map("customer_name")
  customerPhone    String?          @map("customer_phone")
  machineId        String?          @map("machine_id")
  machineType      MachineType?     @map("machine_type")
  machineLabel     String?          @map("machine_label")
  periodType       RentalPeriodType @map("period_type")
  unitPrice        Decimal          @map("unit_price") @db.Decimal(10, 2)
  quantity         Int              @default(1)
  operatorIncluded Boolean          @default(false) @map("operator_included")
  transportCost    Decimal?         @map("transport_cost") @db.Decimal(10, 2)
  discount         Decimal?         @db.Decimal(10, 2)
  taxRate          Decimal          @default(20) @map("tax_rate") @db.Decimal(5, 2)
  subtotal         Decimal          @default(0) @db.Decimal(10, 2)
  taxAmount        Decimal          @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount      Decimal          @default(0) @map("total_amount") @db.Decimal(10, 2)
  validUntil       DateTime?        @map("valid_until")
  status           QuoteStatus      @default(TASLAK)
  token            String?          @unique
  notes            String?
  rentalId         String?          @map("rental_id")
  source           String           @default("MANUEL") @map("source") // MANUEL | MARKETPLACE
  commissionRate   Decimal?         @map("commission_rate") @db.Decimal(5, 2)
  commissionTL     Decimal?         @map("commission_tl") @db.Decimal(10, 2)
  viewedAt         DateTime?        @map("viewed_at")
  respondedAt      DateTime?        @map("responded_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("quotes")
  @@index([tenantId, status])
}

// ─── MARKETPLACE — Kiralama Borsası talep kaydı ──────────
model MarketplaceLead {
  id             String   @id @default(uuid())
  ownerTenantId  String   @map("owner_tenant_id")
  machineId      String   @map("machine_id")
  machineLabel   String?  @map("machine_label")
  requesterName  String   @map("requester_name")
  requesterPhone String?  @map("requester_phone")
  requesterCity  String?  @map("requester_city")
  message        String?
  status         String   @default("YENI") // YENI | ILETILDI | TEKLIF_VERILDI | KAPANDI
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("marketplace_leads")
}

// ─── GÖMÜLÜ FİNTECH — Sigorta/Leasing/Yakıt yönlendirme ──
model ReferralLead {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  type      String // SIGORTA | LEASING | YAKIT
  machineId String?  @map("machine_id")
  note      String?
  contact   String?
  status    String   @default("YENI") // YENI | ILETILDI | KAZANILDI
  createdAt DateTime @default(now()) @map("created_at")

  @@map("referral_leads")
}

// ─── PAZAR: Şantiye Talebi (RFQ) + Çoklu Teklif ─────────
enum RfqStatus {
  ACIK
  TEKLIF_ALDI
  KAPANDI
  IPTAL
}

model Rfq {
  id             String           @id @default(uuid())
  token          String           @unique
  requesterName  String           @map("requester_name")
  requesterPhone String?          @map("requester_phone")
  requesterEmail String?          @map("requester_email")
  city           String?
  machineType    MachineType?     @map("machine_type")
  periodType     RentalPeriodType @default(GUNLUK) @map("period_type")
  quantity       Int              @default(1)
  neededFrom     DateTime?        @map("needed_from")
  operatorNeeded Boolean          @default(false) @map("operator_needed")
  description    String?
  budget         Decimal?         @db.Decimal(10, 2)
  status         RfqStatus        @default(ACIK)
  acceptedBidId  String?          @map("accepted_bid_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  bids RfqBid[]

  @@map("rfqs")
}

model RfqBid {
  id               String           @id @default(uuid())
  rfqId            String           @map("rfq_id")
  tenantId         String           @map("tenant_id")
  machineId        String?          @map("machine_id")
  machineLabel     String?          @map("machine_label")
  unitPrice        Decimal          @map("unit_price") @db.Decimal(10, 2)
  periodType       RentalPeriodType @map("period_type")
  operatorIncluded Boolean          @default(false) @map("operator_included")
  note             String?
  status           String           @default("GONDERILDI") // GONDERILDI | KABUL | RED
  createdAt        DateTime         @default(now()) @map("created_at")

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@map("rfq_bids")
}

// ─── PAZAR: Emanet (Escrow) ödeme ────────────────────────
enum EscrowStatus {
  BEKLIYOR // ödeme bekleniyor
  TUTULUYOR // şantiye yatırdı, platformda tutuluyor
  SERBEST // teslim onayı → kiralamacıya serbest
  IADE // iptal/iade
}

model Escrow {
  id            String       @id @default(uuid())
  payToken      String       @unique @map("pay_token")
  ownerTenantId String       @map("owner_tenant_id")
  rfqId         String?      @map("rfq_id")
  rentalId      String?      @map("rental_id")
  payerName     String       @map("payer_name")
  payerPhone    String?      @map("payer_phone")
  amount        Decimal      @db.Decimal(12, 2)
  commissionTL  Decimal      @default(0) @map("commission_tl") @db.Decimal(12, 2)
  ownerNet      Decimal      @default(0) @map("owner_net") @db.Decimal(12, 2)
  status        EscrowStatus @default(BEKLIYOR)
  fundedAt      DateTime?    @map("funded_at")
  releasedAt    DateTime?    @map("released_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("escrows")
}

// ─── PAZAR: İki-taraflı İtibar / Puan ────────────────────
model MarketplaceReview {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id") // puanlanan kiralama firması
  escrowId     String?  @unique @map("escrow_id")
  rentalId     String?  @map("rental_id")
  rating       Int // 1-5
  comment      String?
  reviewerName String?  @map("reviewer_name")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("marketplace_reviews")
}

// ─── Denetim İzi (admin/hassas işlemler) ────────────────
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id") // etkilenen tenant (null = platform)
  actorId    String   @map("actor_id") // işlemi yapan kullanıcı
  actorEmail String   @map("actor_email")
  action     String // örn: tenant.create, dealer.delete
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  detail     String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
