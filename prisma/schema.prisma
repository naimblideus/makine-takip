generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  PERSONEL
  MUHASEBE
}

enum MachineType {
  FORKLIFT
  EKSAVATOR
  VINC
  DOZER
  KEPCE
  GREYDER
  SILINDIR
  KAMYON
  BEKO_LODER
  DIGER
}

enum MachineStatus {
  MUSAIT
  KIRADA
  BAKIMDA
  ARIZALI
}

enum RentalStatus {
  AKTIF
  TAMAMLANDI
  IPTAL
}

enum RentalPeriodType {
  SAATLIK
  GUNLUK
  HAFTALIK
  AYLIK
}

enum PaymentMethod {
  NAKIT
  KREDI_KARTI
  HAVALE_EFT
  CEK
  SENET
}

enum PaymentStatus {
  ODENDI
  BEKLIYOR
  GECIKTI
  IPTAL
}

enum MaintenanceType {
  YAG_DEGISIMI
  FILTRE
  GENEL_BAKIM
  REVIZYON
  LASTIK
  DIGER
}

enum FuelLevel {
  TAM
  YARI
  CEYREK
  BOS
}

enum TimesheetType {
  NORMAL
  FAZLA_MESAI
  RESMI_TATIL
}

enum InvoiceStatus {
  TASLAK
  ONAYLANDI
  ODENDI
  KISMI_ODENDI
  GECIKTI
  IPTAL
}

enum GpsAction {
  ENGINE_STOP
  ENGINE_START
  SPEED_ALERT
  GEOFENCE_BREACH
  FUEL_THEFT_ALERT
  UNAUTHORIZED_USE
  IDLE_ALERT
}

enum NotificationType {
  BAKIM_YAKLASIYOR
  BAKIM_GECIKTI
  SIGORTA_DOLACAK
  MUAYENE_DOLACAK
  YAKIT_HIRSIZLIGI
  GEOFENCE_IHLALI
  YETKISIZ_KULLANIM
  HIZ_IHLALI
  BOSTA_CALISIYOR
  MOTOR_DURDU
  OPERATOR_BELGESI_DOLACAK
}

// ─── MODELS ──────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  name        String
  logo        String?
  address     String?
  phone       String?
  email       String?
  taxOffice   String?  @map("tax_office")
  taxNumber   String?  @map("tax_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users              User[]
  machines           Machine[]
  operators          Operator[]
  customers          Customer[]
  sites              Site[]
  rentals            Rental[]
  fuelEntries        FuelEntry[]
  maintenances       Maintenance[]
  invoices           Invoice[]
  payments           Payment[]
  timesheets         Timesheet[]
  gpsLogs            GpsLog[]
  engineSessions     EngineSession[]
  geofences          Geofence[]
  geofenceBreaches   GeofenceBreach[]
  fuelTheftAlerts    FuelTheftAlert[]
  systemNotifications SystemNotification[]

  @@map("tenants")
}

model User {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  email         String   @unique
  password      String
  name          String
  role          Role     @default(PERSONEL)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Machine {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  plate           String?
  serialNumber    String?       @map("serial_number")
  brand           String
  model           String
  year            Int?
  type            MachineType
  status          MachineStatus @default(MUSAIT)
  photo           String?
  
  // Fiyatlar
  hourlyRate      Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  dailyRate       Decimal?      @map("daily_rate") @db.Decimal(10, 2)
  weeklyRate      Decimal?      @map("weekly_rate") @db.Decimal(10, 2)
  monthlyRate     Decimal?      @map("monthly_rate") @db.Decimal(10, 2)
  operatorIncRate Decimal?      @map("operator_inc_rate") @db.Decimal(10, 2)
  
  // Belgeler
  registrationDoc String?       @map("registration_doc")
  insuranceExpiry DateTime?     @map("insurance_expiry")
  inspectionExpiry DateTime?    @map("inspection_expiry")
  
  // Sayaç
  totalHours      Decimal       @default(0) @map("total_hours") @db.Decimal(10, 1)

  // GPS & Telemetri
  traccarDeviceId     String?   @map("traccar_device_id")
  speedLimit          Int?      @map("speed_limit")
  gpsEnabled          Boolean   @default(false) @map("gps_enabled")
  fuelCapacity        Decimal?  @map("fuel_capacity") @db.Decimal(10, 1)
  fuelSensorEnabled   Boolean   @default(false) @map("fuel_sensor_enabled")
  engineHoursSensor   Boolean   @default(false) @map("engine_hours_sensor")
  idleThresholdMinutes Int      @default(15) @map("idle_threshold_minutes")
  
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentals         Rental[]
  fuelEntries     FuelEntry[]
  maintenances    Maintenance[]
  gpsLogs         GpsLog[]
  engineSessions  EngineSession[]
  geofenceMachines GeofenceMachine[]
  geofenceBreaches GeofenceBreach[]
  fuelTheftAlerts  FuelTheftAlert[]

  @@map("machines")
}

model Operator {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  name            String
  tcNumber        String?  @map("tc_number")
  phone           String?
  address         String?
  licenseClass    String?  @map("license_class")
  licenseExpiry   DateTime? @map("license_expiry")
  machineTypes    MachineType[] @map("machine_types")
  
  dailyWage       Decimal? @map("daily_wage") @db.Decimal(10, 2)
  hourlyWage      Decimal? @map("hourly_wage") @db.Decimal(10, 2)
  
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentals         Rental[]
  timesheets      Timesheet[]
  engineSessions  EngineSession[]

  @@map("operators")
}

model Customer {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  companyName     String   @map("company_name")
  contactPerson   String?  @map("contact_person")
  phone           String?
  email           String?
  address         String?
  taxOffice       String?  @map("tax_office")
  taxNumber       String?  @map("tax_number")
  
  isBlacklisted   Boolean  @default(false) @map("is_blacklisted")
  blacklistReason String?  @map("blacklist_reason")
  
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sites           Site[]
  rentals         Rental[]
  invoices        Invoice[]

  @@map("customers")
}

model Site {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  customerId      String   @map("customer_id")
  name            String
  address         String?
  mapsLink        String?  @map("maps_link")
  contactPerson   String?  @map("contact_person")
  contactPhone    String?  @map("contact_phone")

  // GPS koordinatları
  lat             Float?
  lng             Float?
  defaultGeofenceRadius Int? @default(500) @map("default_geofence_radius")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rentals         Rental[]
  geofences       Geofence[]

  @@map("sites")
}

model Rental {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  machineId       String        @map("machine_id")
  customerId      String        @map("customer_id")
  siteId          String?       @map("site_id")
  operatorId      String?       @map("operator_id")
  
  status          RentalStatus  @default(AKTIF)
  periodType      RentalPeriodType @map("period_type")
  unitPrice       Decimal       @map("unit_price") @db.Decimal(10, 2)
  operatorIncluded Boolean      @default(false) @map("operator_included")
  
  startDate       DateTime      @map("start_date")
  endDate         DateTime?     @map("end_date")
  actualEndDate   DateTime?     @map("actual_end_date")
  
  // Teslim bilgileri
  deliveryHours   Decimal?      @map("delivery_hours") @db.Decimal(10, 1)
  deliveryKm      Decimal?      @map("delivery_km") @db.Decimal(10, 1)
  deliveryFuel    FuelLevel?    @map("delivery_fuel")
  
  // İade bilgileri
  returnHours     Decimal?      @map("return_hours") @db.Decimal(10, 1)
  returnKm        Decimal?      @map("return_km") @db.Decimal(10, 1)
  returnFuel      FuelLevel?    @map("return_fuel")
  
  deposit         Decimal?      @db.Decimal(10, 2)
  notes           String?
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine         Machine       @relation(fields: [machineId], references: [id])
  customer        Customer      @relation(fields: [customerId], references: [id])
  site            Site?         @relation(fields: [siteId], references: [id])
  operator        Operator?     @relation(fields: [operatorId], references: [id])
  contract        Contract?
  damageRecords   DamageRecord[]
  invoices        Invoice[]
  timesheets      Timesheet[]
  engineSessions  EngineSession[]

  @@map("rentals")
}

model Contract {
  id              String   @id @default(uuid())
  rentalId        String   @unique @map("rental_id")
  pdfPath         String?  @map("pdf_path")
  signatureData   String?  @map("signature_data")
  signedAt        DateTime? @map("signed_at")
  sentAt          DateTime? @map("sent_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  rental          Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

model DamageRecord {
  id              String   @id @default(uuid())
  rentalId        String   @map("rental_id")
  description     String
  location        String?
  photos          String[]
  cost            Decimal? @db.Decimal(10, 2)
  chargedToCustomer Boolean @default(false) @map("charged_to_customer")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  rental          Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("damage_records")
}

model FuelEntry {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  machineId       String   @map("machine_id")
  date            DateTime
  liters          Decimal  @db.Decimal(10, 2)
  cost            Decimal  @db.Decimal(10, 2)
  fuelLevel       String?  @map("fuel_level")
  supplier        String?
  receiptNumber   String?  @map("receipt_number")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine         Machine  @relation(fields: [machineId], references: [id])

  @@map("fuel_entries")
}

model Maintenance {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  machineId       String          @map("machine_id")
  type            MaintenanceType
  description     String?
  cost            Decimal?        @db.Decimal(10, 2)
  parts           String?
  serviceName     String?         @map("service_name")
  photos          String[]
  
  performedAt     DateTime        @map("performed_at")
  machineHoursAt  Decimal?        @map("machine_hours_at") @db.Decimal(10, 1)
  nextMaintenanceHours Decimal?   @map("next_maintenance_hours") @db.Decimal(10, 1)
  nextMaintenanceDate  DateTime?  @map("next_maintenance_date")
  
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine         Machine         @relation(fields: [machineId], references: [id])

  @@map("maintenances")
}

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  customerId      String        @map("customer_id")
  rentalId        String?       @map("rental_id")
  invoiceNumber   String        @map("invoice_number")
  
  status          InvoiceStatus @default(TASLAK)
  
  subtotal        Decimal       @db.Decimal(10, 2)
  taxRate         Decimal       @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal       @map("tax_amount") @db.Decimal(10, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  
  items           Json?
  notes           String?
  pdfPath         String?       @map("pdf_path")
  
  issueDate       DateTime      @map("issue_date")
  dueDate         DateTime?     @map("due_date")
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id])
  rental          Rental?       @relation(fields: [rentalId], references: [id])
  payments        Payment[]

  @@map("invoices")
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  invoiceId       String        @map("invoice_id")
  
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(BEKLIYOR)
  
  paidAt          DateTime?     @map("paid_at")
  dueDate         DateTime?     @map("due_date")
  
  reference       String?
  notes           String?
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Timesheet {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  operatorId      String        @map("operator_id")
  rentalId        String?       @map("rental_id")
  date            DateTime
  type            TimesheetType @default(NORMAL)
  hoursWorked     Decimal       @map("hours_worked") @db.Decimal(4, 1)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operator        Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  rental          Rental?       @relation(fields: [rentalId], references: [id])

  @@map("timesheets")
}

// ─── GPS & TELEMETRİ MODELLERİ ──────────────────────────

model GpsLog {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  machineId   String    @map("machine_id")
  action      GpsAction
  lat         Float?
  lng         Float?
  speed       Float?
  engineOn    Boolean?  @map("engine_on")
  fuelLevel   Float?    @map("fuel_level")
  triggeredBy String?   @map("triggered_by")
  reason      String?
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine     Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("gps_logs")
}

model EngineSession {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  machineId       String    @map("machine_id")
  rentalId        String?   @map("rental_id")
  operatorId      String?   @map("operator_id")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int?      @map("duration_minutes")
  idleMinutes     Int?      @map("idle_minutes")
  workMinutes     Int?      @map("work_minutes")
  maxSpeed        Float?    @map("max_speed")
  avgSpeed        Float?    @map("avg_speed")
  fuelConsumed    Float?    @map("fuel_consumed")
  startLat        Float?    @map("start_lat")
  startLng        Float?    @map("start_lng")
  isAuthorized    Boolean   @default(true) @map("is_authorized")
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine         Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  rental          Rental?   @relation(fields: [rentalId], references: [id])
  operator        Operator? @relation(fields: [operatorId], references: [id])

  @@map("engine_sessions")
}

model Geofence {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  siteId          String?   @map("site_id")
  name            String
  type            String    @default("POLYGON")
  coordinates     Json
  isActive        Boolean   @default(true) @map("is_active")
  actionOnBreach  String    @default("ALERT") @map("action_on_breach")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site            Site?     @relation(fields: [siteId], references: [id])
  assignedMachines GeofenceMachine[]
  breaches        GeofenceBreach[]

  @@map("geofences")
}

model GeofenceMachine {
  id          String   @id @default(uuid())
  geofenceId  String   @map("geofence_id")
  machineId   String   @map("machine_id")
  assignedAt  DateTime @default(now()) @map("assigned_at")

  geofence    Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("geofence_machines")
}

model GeofenceBreach {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  geofenceId  String    @map("geofence_id")
  machineId   String    @map("machine_id")
  lat         Float
  lng         Float
  speed       Float?
  breachType  String    @default("EXIT")
  actionTaken String?   @map("action_taken")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  geofence    Geofence  @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  machine     Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("geofence_breaches")
}

model FuelTheftAlert {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  machineId     String    @map("machine_id")
  detectedAt    DateTime  @map("detected_at")
  fuelBefore    Float     @map("fuel_before")
  fuelAfter     Float     @map("fuel_after")
  difference    Float
  machineWasOn  Boolean   @map("machine_was_on")
  lat           Float?
  lng           Float?
  isResolved    Boolean   @default(false) @map("is_resolved")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machine       Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("fuel_theft_alerts")
}

model SystemNotification {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  type        NotificationType
  title       String
  message     String
  machineId   String?          @map("machine_id")
  rentalId    String?          @map("rental_id")
  isRead      Boolean          @default(false) @map("is_read")
  data        Json?
  createdAt   DateTime         @default(now()) @map("created_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("system_notifications")
}
